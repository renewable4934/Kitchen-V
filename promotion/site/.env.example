# ----------------------------------------
# App
# ----------------------------------------
PORT=3000
NODE_ENV=development

# ----------------------------------------
# Public contact defaults for landing pages
# Use placeholders, then replace with your real values.
# ----------------------------------------
DEFAULT_CITY=Your City
CONTACT_PHONE=+7 (000) 000-00-00
WHATSAPP_PHONE=70000000000

# ----------------------------------------
# CRM integration (choose one)
# If both are empty, leads/events are stored only in local NDJSON files.
# ----------------------------------------
CRM_WEBHOOK_URL=https://your-crm.example.com/webhook
BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/your-webhook-id/crm.lead.add.json
