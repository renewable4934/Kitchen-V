# Title: Environment variables example for promotion/site
# Purpose: safe placeholder values for local launch of the Next.js site, hosted Supabase CMS and server-side lead delivery.
# Owner: Project team
# Last updated: 2026-03-11

# ----------------------------------------
# Runtime
# ----------------------------------------
NODE_ENV=development

# ----------------------------------------
# Hosted Supabase project
# Copy from: Supabase Dashboard -> Project Settings -> API
# ----------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key

# Server-only key for writing leads/events from Next.js route handlers.
# Copy from: Supabase Dashboard -> Project Settings -> API
# Keep this only on the server / GitHub environment secrets.
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------
# Optional CRM delivery
# Leave empty if you only want to store leads in Supabase for now.
# ----------------------------------------
CRM_WEBHOOK_URL=
BITRIX24_WEBHOOK_URL=
